<Window x:Class="DefaultAppLocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="DefaultAppLocker" Height="820" Width="1260" MinHeight="720" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize"
        FontFamily="Segoe UI Variable, Microsoft YaHei UI, Microsoft YaHei, Segoe UI"
        Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#00FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F2F3F3F3"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#D9FFFFFF"/>
        <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="#E6FFFFFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#22000000"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E4000000"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9A000000"/>
        <SolidColorBrush x:Key="TertiaryTextBrush" Color="#72000000"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0A84FF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#0071D6"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="#DCEEFF"/>
        <SolidColorBrush x:Key="NavSelectedBrush" Color="#E9E9E9"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#C42B1C"/>
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#D9FFFFFF"/>
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#55FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryButtonBackgroundBrush" Color="#66FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryButtonForegroundBrush" Color="#E4000000"/>
        <SolidColorBrush x:Key="TitleBarBrush" Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="NavPaneBrush" Color="#66FFFFFF"/>
        <SolidColorBrush x:Key="SubtleHoverBrush" Color="#1A000000"/>
        <SolidColorBrush x:Key="DataGridAlternateRowBrush" Color="#0A000000"/>
        <SolidColorBrush x:Key="DataGridHeaderBorderBrush" Color="#14000000"/>
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#33000000"/>
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#55000000"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PageTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Microsoft YaHei UI, Microsoft YaHei, Segoe UI"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.10"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Microsoft YaHei UI, Microsoft YaHei, Segoe UI"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="SettingsCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="MinHeight" Value="74"/>
        </Style>

        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="16" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="MouseEnter" Handler="HelpMouseEnter"/>
            <EventSetter Event="MouseLeave" Handler="HelpMouseLeave"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>


        <Style x:Key="CaptionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="15" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DangerBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="7" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Indicator" Width="3" Height="16" CornerRadius="2" Background="Transparent" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{TemplateBinding Tag}" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SubtleHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource NavSelectedBrush}"/>
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="11,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Microsoft YaHei UI, Microsoft YaHei, Segoe UI"/>
        </Style>
<Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Margin" Value="4,4,4,12"/>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        </Style>


        <Style TargetType="ScrollBar">
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Opacity" Value="0.45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" CornerRadius="3" Background="{DynamicResource ScrollThumbBrush}" Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.65"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="6"/>
                                <Setter Property="MinHeight" Value="6"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemRoot" Background="Transparent" CornerRadius="18">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource SubtleHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource NavSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource DataGridAlternateRowBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowHeight" Value="42"/>
            <Setter Property="ColumnHeaderHeight" Value="42"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <EventSetter Event="PreviewMouseWheel" Handler="DataGridPreviewMouseWheel"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource NavSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource NavSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DataGridHeaderBorderBrush}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="TemplateCardTemplate">
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="8" Background="{DynamicResource AccentLightBrush}">
                        <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}" Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="选择后在右侧修改" Style="{StaticResource CaptionText}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SnapshotCardTemplate">
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="9" Background="{DynamicResource AccentLightBrush}">
                        <TextBlock Text="&#xE81C;" Style="{StaticResource IconText}" Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="{Binding Alias}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CaptionText}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="QuickProfileCardTemplate">
            <Border Style="{StaticResource SettingsCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="9" Background="{DynamicResource AccentLightBrush}">
                        <TextBlock Text="&#xE713;" Style="{StaticResource IconText}" Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="{Binding Alias}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CaptionText}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
<Border x:Name="WindowChromeRoot" Background="{DynamicResource SurfaceBrush}" CornerRadius="24" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" SnapsToDevicePixels="True" ClipToBounds="True" Loaded="WindowChromeRootLoaded" SizeChanged="WindowChromeRootSizeChanged">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*" MinHeight="560"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource TitleBarBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBarMouseLeftButtonDown">
            <Grid Margin="14,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="26" Height="26" CornerRadius="9" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                    <TextBlock Text="&#xE83D;" Style="{StaticResource IconText}" Foreground="White" FontSize="14"/>
                </Border>
                <TextBlock Grid.Column="1" Text="DefaultAppLocker" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="&#xE921;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Style="{StaticResource CaptionButton}" Click="MinimizeClick" ToolTip="最小化"/>
                    <Button Content="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Style="{StaticResource CaptionButton}" Click="CloseClick" ToolTip="关闭"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource NavPaneBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0" Padding="0,14,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <RadioButton x:Name="HomeNav" GroupName="Navigation" Style="{StaticResource NavButton}" Tag="首页" IsChecked="True" Checked="NavigationChecked">
                            <TextBlock Text="&#xE80F;" Style="{StaticResource IconText}"/>
                        </RadioButton>
                        <RadioButton x:Name="SnapshotNav" GroupName="Navigation" Style="{StaticResource NavButton}" Tag="配置快照" Checked="NavigationChecked">
                            <TextBlock Text="&#xE81C;" Style="{StaticResource IconText}"/>
                        </RadioButton>
                        <RadioButton x:Name="CompareNav" GroupName="Navigation" Style="{StaticResource NavButton}" Tag="配置比较" Checked="NavigationChecked">
                            <TextBlock Text="&#xE8AB;" Style="{StaticResource IconText}"/>
                        </RadioButton>
                        <RadioButton x:Name="QuickNav" GroupName="Navigation" Style="{StaticResource NavButton}" Tag="快捷配置" Checked="NavigationChecked">
                            <TextBlock Text="&#xE713;" Style="{StaticResource IconText}"/>
                        </RadioButton>
                        <RadioButton x:Name="LockNav" GroupName="Navigation" Style="{StaticResource NavButton}" Tag="锁定设置" Checked="NavigationChecked">
                            <TextBlock Text="&#xE83D;" Style="{StaticResource IconText}"/>
                        </RadioButton>
                        <RadioButton x:Name="HelpNav" GroupName="Navigation" Style="{StaticResource NavButton}" Tag="帮助" Checked="NavigationChecked">
                            <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}"/>
                        </RadioButton>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="12,18,12,12" Padding="14">
                        <StackPanel>
                            <TextBlock Text="快速操作" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Button Command="{Binding SaveCommand}" HorizontalAlignment="Stretch" Tag="保存当前配置为时间轴快照，并写入配置文件。">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" Style="{StaticResource IconText}" Foreground="White" Margin="0,0,8,0"/><TextBlock Text="保存配置" Foreground="White"/></StackPanel>
                            </Button>
                            <Button Command="{Binding ApplyCommand}" HorizontalAlignment="Stretch" Tag="调用同目录 SetUserFTA.exe 应用当前目标配置。">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE777;" Style="{StaticResource IconText}" Foreground="White" Margin="0,0,8,0"/><TextBlock Text="恢复配置" Foreground="White"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding CompareCommand}" HorizontalAlignment="Stretch" Tag="比较当前 Windows 默认应用与目标配置。">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8AB;" Style="{StaticResource IconText}" Margin="0,0,8,0"/><TextBlock Text="比较配置"/></StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding ScanCommand}" HorizontalAlignment="Stretch" Tag="重新读取当前用户文件关联和协议关联。">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" Margin="0,0,8,0"/><TextBlock Text="重新扫描"/></StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Pill}" HorizontalAlignment="Stretch" Padding="12,8" Margin="12,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE946;" Style="{StaticResource IconText}" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding SetUserFtaStatus}" Style="{StaticResource CaptionText}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="28,24,28,18">
                <Grid x:Name="HomePage">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="1040">
                            <TextBlock Text="DefaultAppLocker" Style="{StaticResource PageTitleText}"/>
                            <TextBlock Text="默认应用配置、快照、比较和恢复" Style="{StaticResource CaptionText}" Margin="0,0,0,22"/>

                            <UniformGrid Columns="3" Margin="0,0,0,18">
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="当前配置状态" Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding AssociationCount}" Style="{StaticResource ValueText}"/>
                                        <TextBlock Text="关联数量" Style="{StaticResource CaptionText}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                                    <StackPanel>
                                        <TextBlock Text="最近保存时间" Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding LastSnapshotText}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,9,0,7"/>
                                        <TextBlock Text="配置快照" Style="{StaticResource CaptionText}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="快捷覆盖" Style="{StaticResource CaptionText}"/>
                                        <TextBlock Text="{Binding OverrideCount}" Style="{StaticResource ValueText}"/>
                                        <TextBlock Text="模板关联" Style="{StaticResource CaptionText}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>


                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="当前状态" Style="{StaticResource SectionTitleText}"/>
                                    <TextBlock Text="{Binding Status}" Style="{StaticResource CaptionText}" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="SnapshotPage" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="配置快照" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="保存、应用和管理默认应用快照" Style="{StaticResource CaptionText}" Margin="0,0,0,18"/>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,18,0">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                                    <TextBox Text="{Binding SnapshotAlias, UpdateSourceTrigger=PropertyChanged}" ToolTip="输入新建或重命名用的别名"/>
                                    <UniformGrid Columns="2" Margin="0,8,0,0">
                                        <Button Content="新建" Command="{Binding SaveSnapshotProfileCommand}" Tag="把当前扫描结果保存为新的快照配置。"/>
                                        <Button Content="应用" Command="{Binding ApplySnapshotProfileCommand}" Tag="把选中的快照作为目标配置并立即应用。"/>
                                        <Button Content="重命名" Command="{Binding RenameSnapshotProfileCommand}" Style="{StaticResource SecondaryButton}" Tag="用别名输入框重命名选中快照。"/>
                                        <Button Content="删除" Command="{Binding DeleteSnapshotProfileCommand}" Style="{StaticResource SecondaryButton}" Tag="删除选中的快照配置文件。"/>
                                    </UniformGrid>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <TextBlock Text="快照列表" Style="{StaticResource SectionTitleText}"/>
                                    <TextBlock Text="{Binding SelectedSnapshotProfileDisplay, StringFormat=当前选择：{0}}" Style="{StaticResource CaptionText}"/>
                                </StackPanel>
                                <ListBox ItemsSource="{Binding SnapshotProfiles}" SelectedItem="{Binding SelectedSnapshotProfile}" ItemTemplate="{StaticResource SnapshotCardTemplate}"/>
                            </DockPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                            <Border CornerRadius="12" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" ClipToBounds="True">
                                <DataGrid ItemsSource="{Binding Associations}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="标识" Binding="{Binding Identifier}" Width="150"/>
                                    <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="110"/>
                                    <DataGridTextColumn Header="ProgId" Binding="{Binding ProgId}" Width="280"/>
                                    <DataGridTextColumn Header="应用" Binding="{Binding ApplicationName}" Width="230"/>
                                    <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            </Border>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="ComparePage" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="配置比较" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="查看当前 Windows 默认应用与目标配置的差异" Style="{StaticResource CaptionText}" Margin="0,0,0,18"/>
                    </StackPanel>
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="比较配置" Command="{Binding CompareCommand}" Tag="重新扫描当前配置并计算差异。"/>
                            <StackPanel>
                                <TextBlock Text="差异结果" FontWeight="SemiBold"/>
                                <TextBlock Text="点击比较后显示将被修改的关联。" Style="{StaticResource CaptionText}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                        <Border CornerRadius="12" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" ClipToBounds="True">
                            <DataGrid ItemsSource="{Binding Differences}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="标识" Binding="{Binding Identifier}" Width="170"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="120"/>
                                <DataGridTextColumn Header="当前 ProgId" Binding="{Binding CurrentProgId}" Width="320"/>
                                <DataGridTextColumn Header="目标 ProgId" Binding="{Binding TargetProgId}" Width="320"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        </Border>
                    </Border>
                </Grid>

                <Grid x:Name="QuickPage" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="快捷配置" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="为常用默认应用类型选择程序并保存方案" Style="{StaticResource CaptionText}" Margin="0,0,0,18"/>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="340"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid Margin="0,0,18,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="配置项" Style="{StaticResource SectionTitleText}"/>
                                    <ListBox Grid.Row="1" ItemsSource="{Binding Templates}" SelectedValue="{Binding SelectedTemplate}" SelectedValuePath="Template" ItemTemplate="{StaticResource TemplateCardTemplate}" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="配置方案" Style="{StaticResource SectionTitleText}"/>
                                    <TextBlock Text="{Binding SelectedQuickProfileDisplay, StringFormat=当前选择：{0}}" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
                                    <Border Style="{StaticResource Card}" Padding="8" Margin="0,0,0,8" MaxHeight="150">
                                        <ListBox ItemsSource="{Binding QuickProfiles}" SelectedItem="{Binding SelectedQuickProfile}" ItemTemplate="{StaticResource QuickProfileCardTemplate}" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                    </Border>
                                    <TextBox Text="{Binding TemplateProfileAlias, UpdateSourceTrigger=PropertyChanged}" ToolTip="输入新建或重命名用的别名"/>
                                    <UniformGrid Columns="2" Margin="0,8,0,0">
                                        <Button Content="保存方案" Command="{Binding SaveQuickProfileCommand}" Tag="保存当前模板覆盖为独立方案。"/>
                                        <Button Content="套用" Command="{Binding ApplyQuickProfileCommand}" Tag="套用选中的默认应用模板方案并立即应用。"/>
                                        <Button Content="重命名" Command="{Binding RenameQuickProfileCommand}" Style="{StaticResource SecondaryButton}" Tag="重命名选中的模板方案。"/>
                                        <Button Content="删除" Command="{Binding DeleteQuickProfileCommand}" Style="{StaticResource SecondaryButton}" Tag="删除选中的模板方案。"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Width="40" Height="40" CornerRadius="10" Background="{DynamicResource AccentLightBrush}" Margin="0,0,14,0">
                                            <TextBlock Text="&#xE713;" Style="{StaticResource IconText}" Foreground="{DynamicResource AccentBrush}" FontSize="18"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedTemplateTitle}" FontSize="20" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedTemplateDescription}" Style="{StaticResource CaptionText}"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <StackPanel Margin="0,18,0,0" Visibility="{Binding IsOfficeTemplate, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Office 模板不需要输入框。" Style="{StaticResource CaptionText}"/>
                                        <Button Content="应用 Microsoft Office" Command="{Binding QuickApplyTemplateCommand}" HorizontalAlignment="Left" Tag="立即把 Office 支持的格式绑定到 Word、Excel、PowerPoint。"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,18,0,0" Visibility="{Binding IsBrowserTemplate, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="可选择候选应用，也可拖入或选择 exe。" Style="{StaticResource CaptionText}"/>
                                        <DockPanel Margin="0,8,0,8">
                                            <Button DockPanel.Dock="Right" Content="选择 exe" Command="{Binding BrowseExecutableCommand}" Style="{StaticResource SecondaryButton}" Tag="选择自定义目标程序 exe。"/>
                                            <Button DockPanel.Dock="Right" Content="使用候选" Command="{Binding UseCandidateCommand}" Style="{StaticResource SecondaryButton}" Tag="把选中的候选应用作为目标程序。"/>
                                            <TextBox Text="{Binding SelectedExecutable, UpdateSourceTrigger=PropertyChanged}" MinWidth="420" AllowDrop="True" Drop="TargetExecutableDrop" DragOver="TargetExecutableDragOver"/>
                                        </DockPanel>
                                        <WrapPanel>
                                            <Button Content="应用" Command="{Binding QuickApplyTemplateCommand}" Tag="立即应用当前模板到所选程序。"/>
                                            <Button Content="加入覆盖" Command="{Binding AddTemplateCommand}" Style="{StaticResource SecondaryButton}" Tag="保存当前模板覆盖项。"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,18,0,0" Visibility="{Binding IsPdfTemplate, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="可选择候选应用，也可拖入或选择 exe。" Style="{StaticResource CaptionText}"/>
                                        <DockPanel Margin="0,8,0,8">
                                            <Button DockPanel.Dock="Right" Content="选择 exe" Command="{Binding BrowseExecutableCommand}" Style="{StaticResource SecondaryButton}" Tag="选择自定义目标程序 exe。"/>
                                            <Button DockPanel.Dock="Right" Content="使用候选" Command="{Binding UseCandidateCommand}" Style="{StaticResource SecondaryButton}" Tag="把选中的候选应用作为目标程序。"/>
                                            <TextBox Text="{Binding SelectedExecutable, UpdateSourceTrigger=PropertyChanged}" MinWidth="420" AllowDrop="True" Drop="TargetExecutableDrop" DragOver="TargetExecutableDragOver"/>
                                        </DockPanel>
                                        <WrapPanel>
                                            <Button Content="应用" Command="{Binding QuickApplyTemplateCommand}" Tag="立即应用当前模板到所选程序。"/>
                                            <Button Content="加入覆盖" Command="{Binding AddTemplateCommand}" Style="{StaticResource SecondaryButton}" Tag="保存当前模板覆盖项。"/>
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,18,0,0" Visibility="{Binding IsCustomProgramTemplate, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="可选择候选应用，也可拖入或选择 exe。" Style="{StaticResource CaptionText}"/>
                                        <DockPanel Margin="0,8,0,8">
                                            <Button DockPanel.Dock="Right" Content="选择 exe" Command="{Binding BrowseExecutableCommand}" Style="{StaticResource SecondaryButton}" Tag="选择自定义目标程序 exe。"/>
                                            <Button DockPanel.Dock="Right" Content="使用候选" Command="{Binding UseCandidateCommand}" Style="{StaticResource SecondaryButton}" Tag="把选中的候选应用作为目标程序。"/>
                                            <TextBox Text="{Binding SelectedExecutable, UpdateSourceTrigger=PropertyChanged}" MinWidth="420" AllowDrop="True" Drop="TargetExecutableDrop" DragOver="TargetExecutableDragOver"/>
                                        </DockPanel>
                                        <WrapPanel>
                                            <Button Content="应用" Command="{Binding QuickApplyTemplateCommand}" Tag="立即应用当前模板到所选程序。"/>
                                            <Button Content="加入覆盖" Command="{Binding AddTemplateCommand}" Style="{StaticResource SecondaryButton}" Tag="保存当前模板覆盖项。"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                                <Border CornerRadius="12" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" ClipToBounds="True">
                                    <DataGrid ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}" AutoGenerateColumns="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="应用" Binding="{Binding DisplayName}" Width="240"/>
                                        <DataGridTextColumn Header="ProgId" Binding="{Binding ProgId}" Width="280"/>
                                        <DataGridTextColumn Header="支持格式数量" Binding="{Binding MatchedAssociationCount}" Width="120"/>
                                        <DataGridTextColumn Header="Exe" Binding="{Binding ExecutableName}" Width="180"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                </Border>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="LockPage" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="840">
                            <TextBlock Text="锁定设置" Style="{StaticResource PageTitleText}"/>
                            <TextBlock Text="按需开启登录恢复或低频持续锁定" Style="{StaticResource CaptionText}" Margin="0,0,0,18"/>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="外观主题" Style="{StaticResource SectionTitleText}"/>
                                    <TextBlock Text="切换浅色、深色或跟随系统。" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
                                    <WrapPanel>
                                        <Button Content="浅色" Command="{Binding ChangeThemeCommand}" CommandParameter="Light" Style="{StaticResource SecondaryButton}"/>
                                        <Button Content="深色" Command="{Binding ChangeThemeCommand}" CommandParameter="Dark" Style="{StaticResource SecondaryButton}"/>
                                        <Button Content="跟随系统" Command="{Binding ChangeThemeCommand}" CommandParameter="Default" Style="{StaticResource SecondaryButton}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="配置目录" Style="{StaticResource SectionTitleText}"/>
                                    <TextBox Text="{Binding ConfigRoot, Mode=OneWay}" IsReadOnly="True"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Button Content="导出配置" Command="{Binding ExportConfigCommand}" Tag="导出所有配置快照和模板方案。"/>
                                        <Button Content="导入配置" Command="{Binding ImportConfigCommand}" Style="{StaticResource SecondaryButton}" Tag="导入配置包。"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="锁定/恢复使用配置" Style="{StaticResource SectionTitleText}"/>
                                    <TextBlock Text="登录自动恢复和持续锁定会使用这里保存的快照。" Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SelectedSnapshotProfileDisplay, StringFormat=当前选择：{0}}" Style="{StaticResource CaptionText}" Margin="0,0,0,8"/>
                                    <Border Style="{StaticResource Card}" Padding="8" Margin="0,0,0,10" MaxHeight="220">
                                        <ListBox ItemsSource="{Binding SnapshotProfiles}" SelectedItem="{Binding SelectedSnapshotProfile}" ItemTemplate="{StaticResource SnapshotCardTemplate}" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                    </Border>
                                    <Button Content="保存" Command="{Binding SaveLockProfileCommand}" HorizontalAlignment="Left" Tag="保存锁定和恢复所使用的快照配置。"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="登录自动恢复" Style="{StaticResource SectionTitleText}"/>
                                    <CheckBox Content="登录后自动恢复默认应用配置" IsChecked="{Binding RestoreAtLogon}" Margin="4,0,0,10"/>
                                    <Button Content="更新计划任务" Command="{Binding ToggleRestoreTaskCommand}" HorizontalAlignment="Left" Tag="按当前设置创建或删除登录自动恢复计划任务。"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="持续锁定" Style="{StaticResource SectionTitleText}"/>
                                    <CheckBox Content="持续锁定（低频计划任务方式）" IsChecked="{Binding ContinuousLock}" Margin="4,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" Margin="4,0,0,10">
                                        <TextBlock Text="检查间隔秒" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBox Text="{Binding ContinuousIntervalSeconds}" Width="100"/>
                                    </StackPanel>
                                    <Button Content="更新计划任务" Command="{Binding ToggleContinuousTaskCommand}" HorizontalAlignment="Left" Tag="按当前设置创建或删除持续锁定计划任务。"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="HelpPage" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="帮助" Style="{StaticResource PageTitleText}"/>
                        <TextBlock Text="使用说明和当前状态" Style="{StaticResource CaptionText}" Margin="0,0,0,18"/>
                    </StackPanel>
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16">
                        <TextBox Text="{Binding HelpDocument, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" FontSize="13"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="14,0">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Status}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding HelpText}" VerticalAlignment="Center" Foreground="{DynamicResource TertiaryTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="10,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,52" MaxWidth="360"
                Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                CornerRadius="18" Padding="16,12" Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.22"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding ToastMessage}" Foreground="{DynamicResource PrimaryTextBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Border>
</Window>
